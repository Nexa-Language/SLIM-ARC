+
+    // SLIM-ARC: initialize global prefetch scheduler and register tensors.
+    // Each weight's data lives in the mmap region at (mapping->addr + offs).
+    // We register (addr, size, layer) so the scheduler can issue async
+    // madvise(WILLNEED) for future layers during graph_compute.
+    if (use_mmap && !mappings.empty()) {
+        static slim_arc::prefetch_scheduler s_scheduler(2 /*n_threads*/, 3 /*window*/);
+        slim_arc::set_global_prefetch_scheduler(&s_scheduler);
+        for (const auto & it : weights_map) {
+            const auto & w = it.second;
+            if (w.idx >= mappings.size()) continue;
+            void * base = mappings[w.idx]->addr();
+            if (!base) continue;
+            void * tensor_addr = (uint8_t *) base + w.offs;
+            int layer = slim_arc::tensor_layer_from_name(it.first.c_str());
+            s_scheduler.register_tensor(it.first.c_str(), tensor_addr,
+                                        ggml_nbytes(w.tensor), layer);
+        }
+    }
