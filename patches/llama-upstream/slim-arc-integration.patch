+    // selected expert IDs for each MoE layer. We read these and cache them
+    // in the prefetch_scheduler. On the NEXT graph_compute, we use the
+    // previous layer's router output to predict and prefetch the current
+    // layer's active experts (cross-layer prediction).
+    if (status == GGML_STATUS_SUCCESS) {
+        if (auto * s = slim_arc::get_global_prefetch_scheduler()) {
+            int n_nodes = ggml_graph_n_nodes(gf);
+            for (int i = 0; i < n_nodes; ++i) {
+                struct ggml_tensor * t = ggml_graph_node(gf, i);
+                if (!t || !t->name) continue;
+                // MoE router output: tensor named "ffn_moe_topk" containing
+                // selected expert IDs as I32, shape [n_expert_used, n_tokens]
+                if (strstr(t->name, "ffn_moe_topk") != nullptr && t->data != nullptr) {
+                    int layer = slim_arc::tensor_layer_from_name(t->name);
+                    if (layer < 0) continue;
+                    // Read expert IDs from tensor data (I32 type)
+                    int n_expert_used = (int) t->ne[0];
+                    int n_tokens = (int) t->ne[1];
+                    if (n_expert_used <= 0 || n_tokens <= 0) continue;
+                    const int32_t * expert_data = (const int32_t *) t->data;
+                    // Collect unique expert IDs across all tokens in this layer
+                    // (use the first token's selection as prediction for next layer)
+                    std::vector<int> unique_experts;
+                    for (int e = 0; e < n_expert_used && e < 64; ++e) {
+                        int eid = (int) expert_data[e]; // first token's experts
+                        if (eid >= 0) {
+                            bool found = false;
+                            for (int ue : unique_experts) {
+                                if (ue == eid) { found = true; break; }
+                            }
+                            if (!found) unique_experts.push_back(eid);
+                        }
+                    }
+                    if (!unique_experts.empty()) {
+                        s->cache_router_experts(layer, unique_experts.data(),
+                                                (int) unique_experts.size());
+                    }
+                    break; // one router per layer
+                }
+            }
+        }
+    }
 
     return status;
