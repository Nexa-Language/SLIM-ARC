+    if (use_mmap && !mappings.empty()) {
+        static slim_arc::prefetch_scheduler s_scheduler(2 /*n_threads*/, 3 /*window*/);
+        slim_arc::set_global_prefetch_scheduler(&s_scheduler);
+        for (const auto & it : weights_map) {
