+    // SLIM-ARC: notify prefetch scheduler about the current layer being computed.
+    // We infer the "current layer" from the graph nodes by finding the minimum
+    // blk.N layer index in tensor names. This triggers async madvise(WILLNEED)
+    // for future layers.
+    if (auto * s = slim_arc::get_global_prefetch_scheduler()) {
+        int min_layer = INT_MAX;
+        int n_nodes = ggml_graph_n_nodes(gf);
+        for (int i = 0; i < n_nodes; ++i) {
+            struct ggml_tensor * t = ggml_graph_node(gf, i);
+            if (t && t->name) {
+                int layer = slim_arc::tensor_layer_from_name(t->name);
+                if (layer >= 0 && layer < min_layer) {
+                    min_layer = layer;
+                }
+            }
+        }
+        if (min_layer != INT_MAX) {
+            s->notify_layer_compute(min_layer);
+        }
+    }
+
