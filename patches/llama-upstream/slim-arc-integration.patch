+            // only the predicted-active experts via madvise(WILLNEED) on
+            // expert tensor sub-regions.
+            for (int l = min_layer; l <= max_layer; ++l) {
+                int n_cached = 0;
+                const int * cached = s->get_cached_experts(l - 1, &n_cached);
