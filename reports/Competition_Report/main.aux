\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces MoE Router Hook 跨层专家预测。llama.cpp 计算图中的 \texttt  {ffn\_moe\_topk} 张量包含 Router 输出的 top-k expert IDs。SLIM-ARC 在每层计算后提取该张量，缓存 expert IDs，用于预测下一层的激活专家并提前 \texttt  {madvise(WILLNEED)}。由于 Qwen3-Next-80B 的专家权重以 \texttt  {[dim, dim, 512]} 的 3D 合并张量存储，每个专家占 \texttt  {total\_size / 512} 的连续子区域，通过计算偏移量 \texttt  {expert\_addr = base + expert\_id $\times $ per\_expert\_size} 可精确预取。\relax }}{14}{figure.caption.21}\protected@file@percent }
\newlabel{fig:moe_router_hook}{{4}{14}{MoE Router Hook 跨层专家预测。llama.cpp 计算图中的 \texttt {ffn\_moe\_topk} 张量包含 Router 输出的 top-k expert IDs。SLIM-ARC 在每层计算后提取该张量，缓存 expert IDs，用于预测下一层的激活专家并提前 \texttt {madvise(WILLNEED)}。由于 Qwen3-Next-80B 的专家权重以 \texttt {[dim, dim, 512]} 的 3D 合并张量存储，每个专家占 \texttt {total\_size / 512} 的连续子区域，通过计算偏移量 \texttt {expert\_addr = base + expert\_id $\times $ per\_expert\_size} 可精确预取。\relax }{figure.caption.21}{}}
