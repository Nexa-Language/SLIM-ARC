\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces SLIM-ARC 优化全景与协同关系。三类优化协同工作：A. 内核协同类（MADV\_RANDOM 按需加载 + REPACK 禁用）释放物理内存；B. 量化压缩类（IQ4\_XS 权重 + KV q4\_0）从算法侧降低内存需求；C. 计算融合类（FlashAttention + StreamingLLM eviction）减少计算与 KV 开销。三类优化之间存在协同促进关系（A 释放内存 $\to $ B 获得更多 cache $\to $ C 加速 attention）。\relax }}{4}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{4}{SLIM-ARC 优化全景与协同关系。三类优化协同工作：A. 内核协同类（MADV\_RANDOM 按需加载 + REPACK 禁用）释放物理内存；B. 量化压缩类（IQ4\_XS 权重 + KV q4\_0）从算法侧降低内存需求；C. 计算融合类（FlashAttention + StreamingLLM eviction）减少计算与 KV 开销。三类优化之间存在协同促进关系（A 释放内存 $\to $ B 获得更多 cache $\to $ C 加速 attention）。\relax }{figure.caption.2}{}}
